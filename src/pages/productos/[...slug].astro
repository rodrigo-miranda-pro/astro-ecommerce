---
import Layout from '../../components/layout/Layout.astro';
import ProductDetailClient from '../../components/product/ProductDetailClient.jsx';
import { getProductBySlug, getAllProducts } from '../../data/products.js';

export function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug);

if (!product) {
  return Astro.redirect('/productos');
}

const relatedProducts = getAllProducts()
  .filter((p) => p.category === product.category && p.id !== product.id)
  .slice(0, 4);

const breadcrumbLD = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${Astro.site}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${Astro.site}/productos` },
    { "@type": "ListItem", "position": 3, "name": product.name, "item": `${Astro.site}/productos/${product.slug}` }
  ]
};

const productLD = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "image": product.image,
  "category": product.category.replace(/-/g, ' '),
  "offers": {
    "@type": "Offer",
    "price": product.price.toFixed(2),
    "priceCurrency": "PAB",
    "availability": "https://schema.org/InStock",
    "url": `${Astro.site}/productos/${product.slug}`
  }
};
---

<Layout
  title={`${product.name} | Starbucks Panamá`}
  description={product.description}
  image={product.image}
>
  <script type="application/ld+json">
    {JSON.stringify(breadcrumbLD)}
  </script>
  <script type="application/ld+json">
    {JSON.stringify(productLD)}
  </script>

  <section class="container-page py-8">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-[#00754a] no-underline">Inicio</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/productos" class="hover:text-[#00754a] no-underline">Productos</a></li>
        <li aria-hidden="true">/</li>
        <li><span class="text-[#1e3932]" aria-current="page">{product.name}</span></li>
      </ol>
    </nav>

    <ProductDetailClient product={product} client:load />

    {relatedProducts.length > 0 && (
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-[#1e3932] mb-6">También te puede interesar</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedProducts.map((rp) => (
            <a
              href={`/productos/${rp.slug}`}
              class="group bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-100 no-underline"
            >
              <div class="aspect-square overflow-hidden">
                <img
                  src={rp.image}
                  alt={rp.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-3">
                <h3 class="font-semibold text-[#1e3932] text-sm group-hover:text-[#00754a] transition-colors">
                  {rp.name}
                </h3>
                <p class="text-[#00754a] font-bold text-sm mt-1">
                  B/. {rp.price.toFixed(2)}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>
