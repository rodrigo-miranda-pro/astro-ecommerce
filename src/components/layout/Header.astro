---
import CartIcon from '../cart/CartIcon';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/productos', label: 'Productos' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];

const isActive = (href) => {
  if (href === '/') return Astro.url?.pathname === '/';
  return Astro.url?.pathname?.startsWith(href);
};
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm" role="banner">
  <div class="container-page">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 text-[#00754a] no-underline" aria-label="Starbucks Panamá - Ir al inicio">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <circle cx="20" cy="20" r="18" fill="#00754a" />
          <path d="M20 6c-3.5 0-6.5 1.5-8.5 4l1.5 1.5C14.5 9 17 8 20 8c5 0 9 3 10.5 7.5l2.5-1C31 9.5 26 6 20 6z" fill="white" />
          <path d="M20 34c3.5 0 6.5-1.5 8.5-4l-1.5-1.5C25.5 31 23 32 20 32c-5 0-9-3-10.5-7.5l-2.5 1C9 30.5 14 34 20 34z" fill="white" />
          <path d="M20 12c-4 0-7.2 3.2-7.2 7.2h2.4c0-2.6 2.2-4.8 4.8-4.8s4.8 2.2 4.8 4.8h2.4c0-4-3.2-7.2-7.2-7.2z" fill="white" />
          <line x1="20" y1="19.2" x2="20" y2="28" stroke="white" stroke-width="2" stroke-linecap="round" />
          <line x1="14.5" y1="24" x2="25.5" y2="24" stroke="white" stroke-width="2" stroke-linecap="round" />
        </svg>
        <span class="font-bold text-xl tracking-tight hidden sm:inline text-[#1e3932]">STARBUCKS</span>
      </a>

      <nav class="hidden md:flex items-center gap-8" aria-label="Navegación principal">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`font-medium hover:text-[#00754a] transition-colors no-underline text-sm uppercase tracking-wider ${isActive(link.href) ? 'text-[#00754a]' : 'text-[#1e3932]'}`}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-4">
        <a href="/carrito" class="hidden md:flex items-center gap-2 text-[#1e3932] hover:text-[#00754a] transition-colors no-underline" aria-label="Ir al carrito de compras">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
          </svg>
          <span class="text-sm font-medium">Carrito</span>
        </a>
        <CartIcon client:load />
      </div>
    </div>

    <nav class="md:hidden flex justify-center gap-6 pb-3" aria-label="Navegación móvil">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-medium hover:text-[#00754a] transition-colors no-underline text-xs uppercase tracking-wider ${isActive(link.href) ? 'text-[#00754a]' : 'text-[#1e3932]'}`}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
